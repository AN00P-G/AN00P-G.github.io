---
import BaseLayout from "../layouts/BaseLayout.astro"
const pageTitle = "cat";
import App from "../components/App.astro";
---

<BaseLayout pageTitle={pageTitle}>
	<!-- astro slot -->
	<App title="!!MEOW!!" menuItems={["File", "Edit", "View", "Help"]} height="600px" width="900px">
		<div class="cat-intro" id="catIntro">
			<h1 style="font-size: 2.4rem; text-align: center; color: #ff5f57; margin: 0;">⚠ Extreme Seizure Warning</h1>
			<p style="color:#9aa5c0; text-align:center; margin: 0.5rem 0 1.5rem; font-size:0.9rem;">This page contains rapidly flashing content. Continue only if you are comfortable.</p>
			<div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
				<button id="continueBtn">Yes, continue →</button>
				<button id="noBtn">No thanks</button>
			</div>
		</div>
		<div class="cat-video" id="catVideo" style="opacity:0; pointer-events:none; transition: opacity 0.4s ease; height:100%; width:100%; overflow:hidden;">
			<!-- iframe injected by JS on Continue click -->
		</div>
	</App>
</BaseLayout> 

<!-- styles in /public/style/style.css -->

<script>
  // Use event delegation on document.body so buttons work even after React hydration
  document.body.addEventListener('click', (e) => {
    const target = e.target as Element;

    if (target.closest('#noBtn')) {
      window.location.href = '/about';
      return;
    }

    if (target.closest('#continueBtn')) {
      const intro    = document.getElementById('catIntro') as HTMLElement | null;
      const videoDiv = document.getElementById('catVideo')  as HTMLElement | null;
      if (!intro || !videoDiv) return;

      const iframe = document.createElement('iframe');
      iframe.style.cssText = 'width:100%;height:100%;border:none;display:block;';
      iframe.src   = 'https://www.youtube.com/embed/IxX_QHay02M?autoplay=1&mute=0&loop=1&playlist=IxX_QHay02M&controls=0&modestbranding=1&rel=0&disablekb=1';
      iframe.title = 'YouTube video player';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      (iframe as any).allowFullscreen = true;

      videoDiv.appendChild(iframe);
      intro.style.display       = 'none';
      videoDiv.style.opacity    = '1';
      videoDiv.style.pointerEvents = 'auto';
    }
  });
</script>


