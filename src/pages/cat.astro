---
import BaseLayout from "../layouts/BaseLayout.astro"
const pageTitle = "cat";
import App from "../components/App.astro";
---

<BaseLayout pageTitle={pageTitle}>
	<!-- astro slot -->
	<App title="!!MEOW!!" menuItems={["File", "Edit", "View", "Help"]} height="600px" width="900px">
		<div class="cat-intro" id="catIntro">
			<h1 style="font-size: 3rem; text-align: center; margin: 5rem; color: #f00303;">Extreme Seizure Warning...</h1>
			<div style="text-align: center;">
				<button id="continueBtn">Continue</button>
			</div>
		</div>
		<div class="cat-video" id="catVideo" style="opacity:0; pointer-events:none; transition: opacity 0.4s ease; height:100%; width:100%; overflow:hidden;">
			<!-- iframe injected by JS on Continue click -->
		</div>
	</App>
</BaseLayout> 

<!-- styles in /public/style/style.css -->

<script>
	document.getElementById('continueBtn')?.addEventListener('click', () => {
		const intro = document.getElementById('catIntro') as HTMLElement;
		const videoDiv = document.getElementById('catVideo') as HTMLElement;

		// Build iframe only now so autoplay triggers at the right moment
		const iframe = document.createElement('iframe');
		iframe.style.width = '100%';
		iframe.style.height = '100%';
		iframe.style.border = 'none';
		iframe.style.display = 'block';
		iframe.src = 'https://www.youtube.com/embed/IxX_QHay02M?autoplay=1&mute=0&loop=1&playlist=IxX_QHay02M&controls=0&modestbranding=1&rel=0&disablekb=1';
		iframe.title = 'YouTube video player';
		iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
		iframe.allowFullscreen = true;

		videoDiv.appendChild(iframe);

		intro.style.display = 'none';
		videoDiv.style.opacity = '1';
		videoDiv.style.pointerEvents = 'auto';
	});
</script>


