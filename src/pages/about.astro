---
import BaseLayout from "../layouts/BaseLayout.astro"
const pageTitle = "About Me :)";
import App from "../components/App.astro";
---

<BaseLayout pageTitle={pageTitle}>
        <Fragment slot="head">
                <script>
                        if (typeof window !== 'undefined') {
                                const nav = performance.getEntriesByType('navigation')[0];
                                if (nav && nav.type === 'reload') {
                                        window.location.replace('/');
                                }
                        }
                </script>
        </Fragment>

        <div class="about-layout">

                <!-- Top row: bio + photo -->
                <div class="about-top">
                        

                        
                        <div class="about-left">
                                <App title="About Me" menuItems={["File", "Edit", "View", "Help"]} height="auto" width="auto">
                                        <div class="about-copy">
                                                <p>Anoop is a curious, driven person who likes understanding how things actually work instead of just memorizing surface-level stuff. He's into machine learning, ethical hacking, and building things that make sense, especially systems that are transparent and trustworthy. He gets bored fast with nonsense, prefers straight talk, and works best when there's a clear goal in front of him. Tight on resources but not on ambition, he's focused on leveling up his skills and carving out something solid for himself, even when things are messy.</p>
                                        </div>
                                </App>
                        </div>

                                                <div class="about-right">
                                <App title="Image" menuItems={["File", "Edit", "View", "Help"]} height="auto" width="100%">
                                        <div class="about-photo-wrap">
                                                <img class="about-photo" src="/my_pic.jpg" alt="Profile photo" />
                                                <p class="about-name">Anupraj Guragain</p>
                                        </div>
                                </App>
                        </div>

                </div>

                <!-- Bottom: contact spanning full width -->
                <div class="about-contact">
                        <App title="Contact" menuItems={["File", "Edit", "View", "Help"]} height="540px" width="520px">

                                <!-- Tab buttons -->
                                <div class="contact-tabs">
                                        <button class="contact-tab active" data-panel="github">👾 Github</button>
                                        <button class="contact-tab" data-panel="email">✉ Email Me</button>
                                </div>

                                <!-- GitHub panel -->
                                <div class="contact-panel" id="panel-github">
                                        <div class="gh-card">
                                                <img class="gh-avatar" src="https://avatars.githubusercontent.com/AN00P-G" alt="GitHub avatar" />
                                                <div class="gh-info">
                                                        <p class="gh-name">Anupraj Guragain</p>
                                                        <p class="gh-username">@AN00P-G</p>
                                                        <img
                                                                class="gh-contrib"
                                                                src="https://ghchart.rshah.org/6ef2b6/AN00P-G"
                                                                alt="GitHub contribution chart"
                                                        />
                                                        <a class="gh-profile-link" href="https://github.com/AN00P-G" target="_blank" rel="noopener">View profile ↗</a>
                                                </div>
                                        </div>
                                </div>

                                <!-- Email panel (Formspree) -->
                                <div class="contact-panel contact-panel--hidden" id="panel-email">
                                        <form
                                                class="contact-form"
                                                action="https://formspree.io/f/mykdavrl"
                                                method="POST"
                                        >
                                                <label class="cf-label" for="cf-name">Name:</label>
                                                <input  class="cf-input" id="cf-name"    type="text"  name="name"      placeholder="Your name"    required />
                                                <label class="cf-label" for="cf-email">Email:</label>
                                                <input  class="cf-input" id="cf-email"   type="email" name="email"     placeholder="Your email"   required />
                                                <label class="cf-label" for="cf-subject">Subject:</label>
                                                <input  class="cf-input" id="cf-subject" type="text"  name="_subject"  placeholder="Subject"      required />
                                                <label class="cf-label" for="cf-message">Message:</label>
                                                <textarea class="cf-input cf-textarea"   id="cf-message" name="message"  placeholder="Your message" required></textarea>
                                                <button class="cf-submit" type="submit">Send Message →</button>
                                        </form>
                                </div>

                        </App>
                </div>

        </div>
</BaseLayout>

<script>
  // Tab switching for the Contact app
  document.querySelectorAll<HTMLElement>('.contact-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const panelId = tab.dataset.panel!;

      // Update active tab
      tab.closest('.contact-tabs')!.querySelectorAll('.contact-tab').forEach((t) =>
        t.classList.remove('active')
      );
      tab.classList.add('active');

      // Show matching panel, hide others
      document.querySelectorAll<HTMLElement>('.contact-panel').forEach((p) => {
        p.classList.toggle('contact-panel--hidden', p.id !== `panel-${panelId}`);
      });
    });
  });
</script>