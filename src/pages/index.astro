---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "Home";
import Terminal from "../components/Terminal.astro";
---

<BaseLayout pageTitle={pageTitle}>

  <Terminal>
    <pre class="ascii-art" aria-label="ASCII art banner"> 
    ___                               ______                             _     
   /   |  ____  ____  ____  ____     / ____/_  ___________ _____ _____ _(_)___ 
  / /| | / __ \/ __ \/ __ \/ __ \   / / __/ / / / ___/ __ `/ __ `/ __ `/ / __ \
 / ___ |/ / / / /_/ / /_/ / /_/ /  / /_/ / /_/ / /  / /_/ / /_/ / /_/ / / / / /
/_/  |_/_/ /_/\____/\____/ .___/   \____/\__,_/_/   \__,_/\__, /\__,_/_/_/ /_/ 
                        /_/                              /____/                
    </pre>

    <div id="live-log" class="live-log" aria-live="polite"></div>
  </Terminal>

  <script>
    const prompt = 'anoop@portfolio:~$';
    const pause = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

    // React hydrates asynchronously — wait for #live-log to appear in the DOM
    const waitForEl = (sel) => new Promise((resolve) => {
      const el = document.querySelector(sel);
      if (el) return resolve(el);
      const obs = new MutationObserver(() => {
        const found = document.querySelector(sel);
        if (found) { obs.disconnect(); resolve(found); }
      });
      obs.observe(document.body, { childList: true, subtree: true });
    });

    const append = (logEl, type, line, opts = {}) => {
      if (!logEl) return;
      const el = document.createElement('div');
      el.className = `log-line ${type}`;

      if (type === 'cmd') {
        const promptEl = document.createElement('span');
        promptEl.className = 'prompt';
        promptEl.textContent = opts.promptText ? `${opts.promptText} ` : '';

        const cmdEl = document.createElement('span');
        cmdEl.className = 'cmd-text';
        cmdEl.textContent = line;

        el.append(promptEl, cmdEl);
      } else {
        el.textContent = line;
      }

      logEl.appendChild(el);
      logEl.scrollTop = logEl.scrollHeight;
    };

    const formatMs = (ms) => `${Math.max(ms, 0).toFixed(0)}ms`;

    const run = async (logEl) => {
      const target = window.location.origin;
      await pause(500);
      append(logEl, 'cmd', `echo Welcome to my portfolio!`, { promptText: prompt });
      append(logEl, 'info', '> Welcome to my portfolio! Feel free to look around and check out my projects....');
      await pause(1000);
      append(logEl, 'cmd', `curl -I ${target}`, { promptText: prompt });
      append(logEl, 'info', `> Resolving ${window.location.hostname}...`);
      await pause(500);
      append(logEl, 'step', '> Connecting...');
      await pause(500);
      append(logEl, 'step', '> TLS handshake complete');
      await pause(500);
      append(logEl, 'step', '> Sending request');

      const start = performance.now();
      try {
        const res = await fetch(target, { cache: 'no-store' });
        const text = await res.text();
        const dur = performance.now() - start;
        append(logEl, 'info', `> HTTP ${res.status} ${res.statusText || ''}`.trim());
        append(logEl, 'info', `> Downloaded ${text.length} bytes in ${formatMs(dur)}`);
        append(logEl, 'step', '> Rendering page...');
        await pause(500);
        append(logEl, 'ok', '✔ Done');
        for (let i = 5; i >= 1; i--) {
          append(logEl, 'info', `> Redirecting to about page in ${i} sec...`);
          await pause(1000);
        }
        window.location.href = '/about';
      } catch (err) {
        append(logEl, 'error', `! Request failed: ${err?.message || err}`);
      }
    };

    // Wait for React to hydrate the terminal window, then run
    waitForEl('#live-log').then(logEl => run(logEl));
  </script>
</BaseLayout>
