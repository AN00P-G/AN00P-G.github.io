---
---
<header class="screen-header">
	<!-- Left: Activities / App menu -->
	<div class="header-left">
		<div class="header-menu">
		<input type="checkbox" id="menu-toggle" class="menu-toggle" />
		<label for="menu-toggle" class="menu-button" aria-label="Toggle menu">ᯤ Menu</label>
		<label for="menu-toggle" class="menu-overlay"></label>
		<aside class="side-menu">
			<img src="/icons/menu.svg" id="wifi-stack" class="wifi-stack" alt="Menu" />
			<span class="menu-spacer"></span>
		</aside>
		</div>
	</div>
	<!-- Center: clock + date -->
	<div class="header-status">
		<span class="header-clock">--:--</span>
		<span class="header-sep">·</span>
		<span class="header-date">---</span>
	</div>

	<!-- Right: system tray -->
	<div class="header-right" aria-label="Status indicators">
		<span class="tray-item" title="Bluetooth">ᛒ</span>
		<span class="tray-item" title="Sound">🔊</span>
		<span class="tray-item" title="Brightness">🔅</span>
		<span class="tray-item" title="Battery">🔋<span class="battery-pct">98%</span></span>
	</div>
</header>

<!-- styles in /public/style/style.css -->

<script>
	if (typeof window !== 'undefined') {
		const clockEl = document.querySelector('.header-clock');
		const dateEl = document.querySelector('.header-date');
		const fmtTime = new Intl.DateTimeFormat([], { hour: '2-digit', minute: '2-digit' });
		const fmtDay = new Intl.DateTimeFormat([], { weekday: 'short' });
		const update = () => {
			const now = new Date();
			if (clockEl) clockEl.textContent = fmtTime.format(now);
			if (dateEl) dateEl.textContent = fmtDay.format(now);
		};
		update();
		setInterval(update, 60000);

		const toggle = document.getElementById('menu-toggle');
		const body = document.body;
		if (toggle && body) {
			const syncMenuState = () => {
				body.classList.toggle('menu-open', toggle.checked);
			};
			toggle.addEventListener('change', syncMenuState);
			syncMenuState();
		}

		// WiFi menu: route click based on y-position within image
		// Arcs are positioned in the 2000x2000 canvas at:
		// about y≈270 (13.5%), project y≈660 (33%), resume y≈1067 (53%), cat y≈1430 (71%)
		const wifiStack = document.getElementById('wifi-stack');
		if (wifiStack) {
			wifiStack.addEventListener('click', (e) => {
				const rect = wifiStack.getBoundingClientRect();
				const yPct = (e.clientY - rect.top) / rect.height; // 0..1 from top

				let href;
				if      (yPct < 0.22) href = '/about';
				else if (yPct < 0.43) href = '/projects';
				else if (yPct < 0.63) href = '/resume';
				else                  href = '/cat';

				window.location.href = href;
			});
			wifiStack.style.cursor = 'pointer';
		}
	}
</script>