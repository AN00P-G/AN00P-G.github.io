<footer id="taskbar">
  <div class="taskbar-apps" id="taskbar-apps">
    <!-- populated by script -->
  </div>
</footer>

<script>

  function buildTaskbar() {
    const bar = document.getElementById('taskbar-apps');
    if (!bar) return;
    bar.innerHTML = '';

    document.querySelectorAll<HTMLElement>('.lw-container').forEach((win, i) => {
      const titleEl = win.querySelector<HTMLElement>('.lw-title');
      const label   = titleEl?.textContent?.trim() || `App ${i + 1}`;

      const btn = document.createElement('button');
      btn.className = 'tb-btn';
      btn.textContent = label;
      btn.dataset.winIndex = String(i);

      // store reference
      (btn as any)._win = win;

      btn.addEventListener('click', () => {
        const isClosed    = win.classList.contains('lw-closed');
        const isMinimized = win.classList.contains('lw-minimized');

        if (isClosed) {
          // reopen
          win.classList.remove('lw-closed');
          win.classList.remove('lw-minimized');
        } else if (isMinimized) {
          // restore
          win.classList.remove('lw-minimized');
        } else {
          // already visible → minimize
          win.classList.add('lw-minimized');
        }
        // Bring to front
        win.style.zIndex = String(Date.now());
        // scroll into view (for non-dragged windows)
        if (!win.classList.contains('lw-dragged')) {
          win.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        refreshStates();
      });

      bar.appendChild(btn);
    });

    refreshStates();
  }

  function refreshStates() {
    document.querySelectorAll<HTMLElement>('.tb-btn').forEach((btn) => {
      const win: HTMLElement = (btn as any)._win;
      if (!win) return;
      const isClosed    = win.classList.contains('lw-closed');
      const isMinimized = win.classList.contains('lw-minimized');
      btn.classList.toggle('tb-closed',    isClosed);
      btn.classList.toggle('tb-minimized', !isClosed && isMinimized);
      btn.classList.toggle('tb-active',    !isClosed && !isMinimized);
    });
  }

  // Build after DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    buildTaskbar();

    // Re-sync whenever a window's class changes (minimize/close/restore)
    const observer = new MutationObserver(refreshStates);
    document.querySelectorAll<HTMLElement>('.lw-container').forEach((win) => {
      observer.observe(win, { attributes: true, attributeFilter: ['class'] });
    });
  });
</script>