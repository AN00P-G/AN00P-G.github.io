---
// src/components/App.astro
// Wrapper for the React WindowManager component
import WindowManager from './App.jsx';

interface Props {
  title?: string;
  menuItems?: string[];
  height?: string;
  width?: string;
  monospace?: boolean;
  noPad?: boolean;
  items?: number;
}

const {
  title      = "anoop@portfolio: ~",
  menuItems  = ["File", "Edit", "View", "Help"],
  height     = "600px",
  width      = "1000px",
  monospace  = false,
  noPad      = false,
  items      = 1,
} = Astro.props;
---

<WindowManager
  client:load
  {title}
  {menuItems}
  {height}
  {width}
  {monospace}
  {noPad}
  {items}
>
  <slot />
</WindowManager>

