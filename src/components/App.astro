---
// src/components/App.astro
// A reusable Linux-style desktop window chrome.
//
// Props:
//   title       – text shown in the title bar          (default: "anoop@portfolio: ~")
//   menuItems   – array of menu label strings          (default: terminal menu)
//   height      – CSS height of the window             (default: "600px")
//   width       – CSS max-width of the window          (default: "1000px")
//   monospace   – use monospace font for the body      (default: false)
//   noPad       – remove body padding (e.g. for grids) (default: false)

interface Props {
  title?: string;
  menuItems?: string[];
  height?: string;
  width?: string;
  monospace?: boolean;
  noPad?: boolean;
}

const {
  title      = "anoop@portfolio: ~",
  menuItems  = ["File", "Edit", "View", "Help"],
  height     = "600px",
  width      = "1000px",
  monospace  = false,
  noPad      = false,
} = Astro.props;
---

<div
  class="lw-container"
  style={`--lw-height:${height}; --lw-width:${width};`}
>
  <!-- ── Title bar ── -->
  <div class="lw-titlebar">
    <span class="lw-title">{title}</span>
    <div class="lw-wm-buttons">
      <span class="lw-btn lw-min" title="Minimize">&#8722;</span>
      <span class="lw-btn lw-max" title="Maximize">&#9633;</span>
      <span class="lw-btn lw-close" title="Close">&#10005;</span>
    </div>
  </div>

  <!-- ── Menu bar ── -->
  {menuItems.length > 0 && (
    <div class="lw-menubar">
      {menuItems.map((item) => (
        <span class="lw-menu-item">{item}</span>
      ))}
    </div>
  )}

  <!-- ── Content ── -->
  <div class={`lw-body${monospace ? " lw-mono" : ""}${noPad ? " lw-nopad" : ""}`}>
    <slot />
  </div>
</div>

<!-- styles in /public/style/style.css -->

<script>
  // Shared z-index counter — start high so taskbar (99998) stays on top
  // Export to window so Footer.astro taskbar can stay in sync.
  if (!(window as any)._lwZTop) (window as any)._lwZTop = 1000;
  const nextZ = () => ++(window as any)._lwZTop;

  const isMobile = () => window.innerWidth <= 768;

  function reparentToScreen(win: HTMLElement) {
    if (isMobile()) return; // keep windows in their flex containers on mobile
    const screen = document.querySelector<HTMLElement>('#screen') || document.body;
    if (win.parentElement !== screen) {
      // Snapshot position relative to #screen before moving
      const screenRect = screen.getBoundingClientRect();
      const wRect      = win.getBoundingClientRect();
      const cell       = win.parentElement as HTMLElement;
      if (cell) {
        cell.style.width  = cell.offsetWidth  + 'px';
        cell.style.height = cell.offsetHeight + 'px';
      }
      win.style.left  = (wRect.left - screenRect.left + screen.scrollLeft) + 'px';
      win.style.top   = (wRect.top  - screenRect.top  + screen.scrollTop)  + 'px';
      win.style.width = win.offsetWidth + 'px';
      win.classList.add('lw-dragged');
      // Only append when actually moving to a new parent
      screen.appendChild(win);
    }
    // Already in #screen — just update z-index (caller's job), don't re-append
    // (re-appending during mousedown kills pending click events on children)
  }

  // Eagerly reparent ALL windows on load so close/minimize never shifts flex layout
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLElement>('.lw-container').forEach((win) => {
      reparentToScreen(win);
    });
  });

  // ── Window manager buttons ──
  document.querySelectorAll<HTMLElement>('.lw-wm-buttons').forEach((btns) => {
    const win = btns.closest<HTMLElement>('.lw-container')!;
    const maxBtn = btns.querySelector<HTMLElement>('.lw-max')!;

    btns.querySelector('.lw-close')!.addEventListener('click', () => {
      win.classList.add('lw-closed');
    });

    btns.querySelector('.lw-min')!.addEventListener('click', () => {
      win.classList.remove('lw-maximized');
      win.classList.toggle('lw-minimized');
      maxBtn.innerHTML = '&#9633;';
    });

    maxBtn.addEventListener('click', () => {
      win.classList.remove('lw-minimized');
      const isMax = win.classList.toggle('lw-maximized');
      maxBtn.innerHTML = isMax ? '&#10697;' : '&#9633;';
      if (isMax) {
        // Save current inline position so we can restore on un-maximize
        win.dataset.preMaxTop    = win.style.top;
        win.dataset.preMaxLeft   = win.style.left;
        win.dataset.preMaxWidth  = win.style.width;
        win.dataset.preMaxHeight = win.style.height;
        reparentToScreen(win);
        // Offset from the header bar and taskbar so they stay visible
        const headerEl  = document.querySelector<HTMLElement>('.screen-header');
        const taskbarEl = document.querySelector<HTMLElement>('#taskbar');
        const headerH   = headerEl  ? headerEl.offsetHeight  : 0;
        const taskbarH  = taskbarEl ? taskbarEl.offsetHeight : 0;
        win.style.top    = headerH + 'px';
        win.style.left   = '0';
        win.style.width  = '100%';
        win.style.height = `calc(100% - ${headerH}px - ${taskbarH + 10}px)`;
        win.style.zIndex = String(nextZ());
      } else {
        // Restore pre-maximize position
        win.style.top    = win.dataset.preMaxTop    || '';
        win.style.left   = win.dataset.preMaxLeft   || '';
        win.style.width  = win.dataset.preMaxWidth  || '';
        win.style.height = win.dataset.preMaxHeight || '';
      }
    });
  });

  // ── Drag to move ──
  document.querySelectorAll<HTMLElement>('.lw-titlebar').forEach((titlebar) => {
    const win = titlebar.closest<HTMLElement>('.lw-container')!;
    let dragging = false;
    let ox = 0, oy = 0;

    const bringToFront = () => {
      reparentToScreen(win);
      win.style.zIndex = String(nextZ());
    };

    // Raise on click — but NOT when clicking the WM buttons (close/min/max)
    win.addEventListener('mousedown', (e) => {
      if ((e.target as HTMLElement).closest('.lw-wm-buttons')) return;
      bringToFront();
    });
    win.addEventListener('touchstart', (e) => {
      if ((e.target as HTMLElement).closest('.lw-wm-buttons')) return;
      bringToFront();
    }, { passive: true });

    const startDrag = (cx: number, cy: number) => {
      if (isMobile()) return;
      if (win.classList.contains('lw-maximized')) return;
      bringToFront();
      ox = cx - win.offsetLeft;
      oy = cy - win.offsetTop;
      dragging = true;
    };

    const moveDrag = (cx: number, cy: number) => {
      if (!dragging) return;
      win.style.left = (cx - ox) + 'px';
      win.style.top  = (cy - oy) + 'px';
    };

    const stopDrag = () => { dragging = false; };

    // Mouse
    titlebar.addEventListener('mousedown', (e) => {
      if ((e.target as HTMLElement).closest('.lw-wm-buttons')) return;
      startDrag(e.clientX, e.clientY);
      e.preventDefault();
    });
    document.addEventListener('mousemove', (e) => moveDrag(e.clientX, e.clientY));
    document.addEventListener('mouseup', stopDrag);

    // Touch
    titlebar.addEventListener('touchstart', (e) => {
      if ((e.target as HTMLElement).closest('.lw-wm-buttons')) return;
      const t = e.touches[0];
      startDrag(t.clientX, t.clientY);
    }, { passive: true });
    document.addEventListener('touchmove', (e) => {
      const t = e.touches[0];
      moveDrag(t.clientX, t.clientY);
    }, { passive: true });
    document.addEventListener('touchend', stopDrag);
  });
</script>
